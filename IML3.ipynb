        {
        "cell_type": "code",
        "execution_count": null,
        "id": "langchain_ip5310_agent",
        "metadata": {
        "id": "langchain_ip5310_agent"
        },
        "outputs": [],
        "source": [
        "# 🔗 Part D: 用 LangGraph 重新實作 IP5310 顧問\n",
        "# 這展現了使用框架(LangChain/LangGraph)如何簡化 Agent 的開發流程\n",
        "\n",
        "from langchain.tools import tool\n",
        "from langgraph.prebuilt import create_react_agent\n",
        "import json\n",
        "\n",
        "# === [Step 1] 將現有工具包裝成 LangChain Tools ===\n",
        "\n",
        "@tool\n",
        "def lc_query_ip5310_spec(feature: str) -> str:\n",
        "    \"\"\"查詢 IP5310 晶片的詳細規格參數，包含充電、放電、電量顯示與保護機制。\"\"\"\n",
        "    return json.dumps(query_ip5310_spec(feature), ensure_ascii=False)\n",
        "\n",
        "@tool\n",
        "def lc_calc_power_bank_runtime(capacity_mah: int, output_current: float = 2.0) -> str:\n",
        "    \"\"\"計算行動電源在指定負載(A)下的預估續航時間(h)。\"\"\"\n",
        "    return json.dumps(calc_power_bank_runtime(capacity_mah, output_current=output_current), ensure_ascii=False)\n",
        "\n",
        "@tool\n",
        "def lc_search_design_guide(query: str) -> str:\n",
        "    \"\"\"搜尋 IP5310 的電路設計與 PCB Layout 建議，包含電感電容挑選、散熱、Type-C 配置。\"\"\"\n",
        "    return json.dumps(search_design_guide(query), ensure_ascii=False)\n",
        "\n",
        "ip5310_lc_tools = [lc_query_ip5310_spec, lc_calc_power_bank_runtime, lc_search_design_guide]\n",
        "\n",
        "# === [Step 2] 建立 LangGraph Agent ===\n",
        "\n",
        "# 確保 chat_model 已在 Part B: Step B1 中定義\n",
        "try:\n",
        "    # 使用框架內建的 create_react_agent，它會自動處理 Thought/Action/Observation 的循環\n",
        "    ip5310_agent = create_react_agent(chat_model, ip5310_lc_tools)\n",
        "    print(\"✅ IP5310 LangGraph Agent 建立完成\")\n",
        "except NameError:\n",
        "    print(\"❌ 錯誤: 找不到 chat_model。請確保已執行 Part B: Step B1 單元格。\")\n",
        "\n",
        "# === [Step 3] 執行顧問諮詢 ===\n",
        "\n",
        "def run_langchain_consultant():\n",
        "    question = \"我想用 IP5310 做一個 10000mAh 的 18650 行動電源，請告訴我這顆晶片的放電能力，並幫我計算在 2A 輸出下能撐多久，最後給我一點 PCB 設計的建議。\"\n",
        "\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(f\"🚀 LangChain 版 IP5310 顧問啟動...\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    # 執行 Agent\n",
        "    inputs = {\"messages\": [(\"user\", question)]}\n",
        "    result = ip5310_agent.invoke(inputs)\n",
        "\n",
        "    print(\"\\n🎯 框架版顧問最終建議:\")\n",
        "    print(result[\"messages\"][-1].content)\n",
        "    print(\"=\"*60)\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    run_langchain_consultant()\n"
        ]
        },
