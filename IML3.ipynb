        "        \"default\": \"找不到相關 SOP 段落\",\n",
        "    }\n",
        "    # 簡易關鍵字 match(實際應用會用 embedding)\n",
        "    for keyword, content in sop_db.items():\n",
        "        if keyword in query:\n",
        "            return {\"query\": query, \"result\": content}\n",
        "    return {\"query\": query, \"result\": sop_db[\"default\"]}\n",
        "\n",
        "\n",
        "# 統一的 tool registry\n",
        "TOOLS = {\n",
        "    \"query_yield\": query_yield,\n",
        "    \"query_machine_status\": query_machine_status,\n",
        "    \"search_sop\": search_sop,\n",
        "}\n",
        "\n",
        "print(f\"✅ 註冊了 {len(TOOLS)} 個 tool: {list(TOOLS.keys())}\")"
