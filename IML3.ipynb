        "def react_loop(question: str, max_iters: int = 6, verbose: bool = True) -> str:\n",
        "    \"\"\"\n",
        "    純手寫的 ReAct loop。\n",
        "    \"\"\"\n",
        "    prompt = REACT_PROMPT.format(question=question)\n",
        "\n",
        "    for i in range(max_iters):\n",
        "        if verbose:\n",
        "            print(f\"\\n{'━' * 50}\")\n",
        "            print(f\"🔄 Iteration {i + 1}\")\n",
        "            print(f\"{'━' * 50}\")\n",
        "\n",
        "        # LLM 生成下一步(加 stop string 避免它自己編造 Observation)\n",
        "        llm_output = llm_generate(prompt, max_new_tokens=300, stop_str=\"Observation:\")\n",
        "\n",
        "        if verbose:\n",
        "            print(f\"🤖 LLM 輸出:\\n{llm_output}\\n\")\n",
        "\n",
        "        # Parse\n",
        "        parsed = parse_react_output(llm_output)\n",
        "\n",
        "        if parsed[\"done\"]:\n",
        "            if verbose:\n",
        "                print(f\"✅ Final Answer:\\n{parsed['answer']}\")\n",
        "            return parsed[\"answer\"]\n",
        "\n",
        "        # 執行 tool\n",
        "        action = parsed[\"action\"]\n",
        "        action_input = parsed[\"action_input\"]\n",
        "\n",
        "        if action not in TOOLS:\n",
        "            observation = f\"Error: 未知的 tool {action}\"\n",
        "        else:\n",
        "            try:\n",
        "                result = TOOLS[action](**action_input)\n",
        "                observation = json.dumps(result, ensure_ascii=False)\n",
        "            except Exception as e:\n",
        "                observation = f\"Error: {str(e)}\"\n",
        "\n",
        "        if verbose:\n",
        "            print(f\"⚙️  執行 {action}({action_input})\")\n",
        "            print(f\"📦 Observation: {observation[:200]}...\")\n",
        "\n",
        "        # 把這一輪加到 prompt\n",
        "        prompt = prompt + llm_output + \"\\nObservation: \" + observation + \"\\n\"\n",
        "\n",
        "    return \"超過最大迭代次數\"\n",
        "\n",
        "\n",
        "# 🧪 跑一個 demo\n",
        "print(\"=\" * 60)\n",
        "print(\"Question: SMT-A 產線良率掉到 98.2%,幫我找出根本原因並建議處理方式\")\n",
        "print(\"=\" * 60)\n",
        "answer = react_loop(\"SMT-A 產線良率掉到 98.2%,幫我找出根本原因並建議處理方式\")\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"🎯 最終答案:\")\n",
        "print(answer)\n",
        "print(\"=\" * 60)"
      ]
    },
