        "# 🔋 IP5310 行動電源設計專業 Agent (一鍵執行版)\n",
        "# 此單元格包含：1. 深度知識庫工具 2. 專屬 ReAct Prompt 3. 知識庫注入與執行邏輯\n",
        "\n",
        "import json, re\n",
        "\n",
        "# === [Step 1] 定義深度知識庫工具 (基於官方 Datasheet) ===\n",
        "\n",
        "def query_ip5310_spec(feature: str) -> dict:\n",
        "    \"\"\"查詢 IP5310 晶片的詳細規格參數\"\"\"\n",
        "    specs = {\n",
        "        \"基本特性\": \"IP5310 是一款集成同步開關升壓轉換器、3A 電池充電管理、電池電量指示與 USB Type-C 協議的多功能電源管理 SOC。待機電流 <100µA, I2C 地址 0xEA。\",\n",
        "        \"充電規格\": \"支持同步開關充電, 最大電流 3.0A, 效率 92%。可透過 VSET 設置 4.2V/4.35V/4.4V 電池。\",\n",
        "        \"放電規格\": \"同步開關升壓輸出 5V, 最大電流 3.1A, 效率高達 93% (2A時)。支持自動負載檢測與休眠。\",\n",
        "        \"電量顯示\": \"內置 14bit ADC, 支持 1/2/3/4 顆 LED 顯示。集成 Type-C CC 邏輯, 需外接 5.1k 下拉電阻。\",\n",
        "        \"保護機制\": \"輸入過壓(最高12V)/欠壓保護、輸出過流/短路/過壓保護、電池過充/過放/過流保護、OTP 過溫保護。\"\n",
        "    }\n",
        "    for k, v in specs.items():\n",
        "        if k in feature or feature in k:\n",
        "            return {\"feature\": k, \"detail\": v}\n",
        "    return {\"error\": \"找不到相關規格\", \"available\": list(specs.keys())}\n",
        "\n",
        "def calc_power_bank_runtime(capacity_mah: int, output_voltage: float = 5.0, output_current: float = 2.0, efficiency: float = 0.93) -> dict:\n",
        "    \"\"\"計算行動電源在指定負載下的預估續航時間\"\"\"\n",
        "    # 假設電池平均平台電壓 3.7V\n",
        "    total_wh = (capacity_mah / 1000.0) * 3.7\n",
        "    output_power = output_voltage * output_current\n",
        "    runtime_hours = (total_wh * efficiency) / output_power\n",
        "    return {\n",
        "        \"capacity_mah\": capacity_mah,\n",
        "        \"output_current_a\": output_current,\n",
        "        \"estimated_runtime_h\": round(runtime_hours, 2),\n",
        "        \"efficiency_used\": efficiency,\n",
        "        \"note\": f\"基於 IP5310 標稱 {efficiency*100}% 效率與 3.7V 平均電池電壓\"\n",
