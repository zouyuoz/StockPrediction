        "from langchain.tools import tool\n",
        "\n",
        "\n",
        "@tool\n",
        "def lc_query_yield(line: str, last_n_hours: int = 6) -> str:\n",
        "    \"\"\"查詢 SMT 產線最近 N 小時的良率記錄。\n",
        "\n",
        "    Args:\n",
        "        line: 產線代號(如 'SMT-A')\n",
        "        last_n_hours: 查詢的時間範圍(小時)\n",
        "    \"\"\"\n",
        "    return json.dumps(query_yield(line, last_n_hours), ensure_ascii=False)\n",
        "\n",
        "\n",
        "@tool\n",
        "def lc_query_machine_status(machine_id: str) -> str:\n",
        "    \"\"\"查詢設備當前運行參數與規格。可用設備:PRINTER-3, MOUNT-1, REFLOW-2\n",
        "\n",
        "    Args:\n",
        "        machine_id: 設備代號\n",
        "    \"\"\"\n",
        "    return json.dumps(query_machine_status(machine_id), ensure_ascii=False)\n",
        "\n",
        "\n",
        "@tool\n",
        "def lc_search_sop(query: str) -> str:\n",
        "    \"\"\"從 SOP 文件中搜尋相關規定。\n",
        "\n",
        "    Args:\n",
        "        query: 搜尋關鍵字(中文)\n",
        "    \"\"\"\n",
        "    return json.dumps(search_sop(query), ensure_ascii=False)\n",
        "\n",
        "\n",
        "lc_tools = [lc_query_yield, lc_query_machine_status, lc_search_sop]\n",
        "print(f\"✅ {len(lc_tools)} 個 LangChain tool 包裝完成\")"
      ]
    },
