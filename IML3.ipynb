      "source": [
        "def parse_react_output(text: str) -> dict:\n",
        "    \"\"\"\n",
        "    從 LLM 輸出抓出 Action / Action Input / Final Answer。\n",
        "    回傳 dict:\n",
        "        - 如果有 Final Answer:{\"done\": True, \"answer\": \"...\"}\n",
        "        - 如果有 Action:{\"done\": False, \"action\": \"...\", \"action_input\": {...}}\n",
        "    \"\"\"\n",
        "    # 先看有沒有 Final Answer\n",
        "    final_match = re.search(r\"Final Answer:\\s*(.+?)(?:\\n\\n|$)\", text, re.DOTALL)\n",
        "    if final_match:\n",
        "        return {\"done\": True, \"answer\": final_match.group(1).strip()}\n",
        "\n",
        "    # 沒有 Final Answer,抓 Action + Action Input\n",
        "    action_match = re.search(r\"Action:\\s*([\\w_]+)\", text)\n",
        "    input_match = re.search(r\"Action Input:\\s*(\\{.*?\\})\", text, re.DOTALL)\n",
        "\n",
        "    if not action_match or not input_match:\n",
        "        return {\"done\": True, \"answer\": text}  # 沒有清楚的 action,當作 final\n",
        "\n",
        "    try:\n",
        "        action_input = json.loads(input_match.group(1))\n",
        "    except json.JSONDecodeError:\n",
        "        action_input = {}\n",
        "\n",
        "    return {\n",
        "        \"done\": False,\n",
        "        \"action\": action_match.group(1),\n",
        "        \"action_input\": action_input,\n",
        "    }\n",
        "\n",
        "\n",
        "# 🧪 測試 parser\n",
        "test_output = \"\"\"Thought: 我需要先查產線良率\n",
        "Action: query_yield\n",
        "Action Input: {\"line\": \"SMT-A\", \"last_n_hours\": 6}\"\"\"\n",
        "print(parse_react_output(test_output))"
      ]
    },
